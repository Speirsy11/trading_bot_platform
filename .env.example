# ──────────────────────────────────────────────
# Database (PostgreSQL + TimescaleDB)
# ──────────────────────────────────────────────
DATABASE_URL=postgresql://trading_bot:changeme@localhost:5432/trading_bot_dev

# ──────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ──────────────────────────────────────────────
# API Server
# ──────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0

# ──────────────────────────────────────────────
# Dashboard
# ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=http://localhost:3001

# ──────────────────────────────────────────────
# Security
# ──────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_AUTH_TOKEN=
# Comma-separated allowed CORS origins.
# Required in production; defaults to http://localhost:3000,http://localhost:3001 in dev/test.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ──────────────────────────────────────────────
# Rate limiting
# ──────────────────────────────────────────────
# Max requests per minute per IP on the tRPC endpoint (default 300)
RATE_LIMIT_MAX=300
# Max tRPC requests per minute per bearer token (default 60)
PER_TOKEN_RATE_LIMIT=60

# ──────────────────────────────────────────────
# Live trading safeguards
# ──────────────────────────────────────────────
# Hard cap on any single manual order's notional value (amount × price)
MAX_NOTIONAL_USD=10000
# Per-bot maximum loss in a rolling 24h window before auto-pause
DAILY_LOSS_LIMIT_USD=500

# ──────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────
LOG_LEVEL=info

# ──────────────────────────────────────────────
# Trading
# ──────────────────────────────────────────────
TRADING_ENABLED=false

# ──────────────────────────────────────────────
# Exchange API keys — DATA COLLECTION (read-only)
# Used by the data pipeline for OHLCV ingestion.
# Enable "Read Info" only. No trading, no withdrawals.
# ──────────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=

KRAKEN_API_KEY=
KRAKEN_API_SECRET=

KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_API_PASSPHRASE=

BYBIT_API_KEY=
BYBIT_API_SECRET=

COINBASE_API_KEY=
COINBASE_API_SECRET=

BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=

# ──────────────────────────────────────────────
# Binance Testnet — CI / LT-7 sandbox tests
# Get keys at: https://testnet.binance.vision (login with GitHub)
# Safe to commit to CI secrets; fake money only.
# ──────────────────────────────────────────────
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

# ──────────────────────────────────────────────
# Observability — Sentry (OP-1)
# Free tier: 5k errors/month. https://sentry.io
# ──────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# For the Next.js frontend (must be NEXT_PUBLIC_ to reach the browser bundle)
NEXT_PUBLIC_SENTRY_DSN=

# ──────────────────────────────────────────────
# Observability — Grafana Cloud / Loki (OP-5)
# Free 50GB logs/month. https://grafana.com/products/cloud/
# ──────────────────────────────────────────────
LOKI_URL=
LOKI_USER=
LOKI_PASSWORD=

# ──────────────────────────────────────────────
# Alerts — Discord webhook (OP-4)
# Server Settings → Integrations → Webhooks → New Webhook → Copy URL
# ──────────────────────────────────────────────
DISCORD_WEBHOOK_URL=

# Alerts — Telegram bot (OP-4, alternative to Discord)
# Create a bot via @BotFather, then get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ──────────────────────────────────────────────
# Backups — S3-compatible storage (OP-6)
# Cloudflare R2: https://dash.cloudflare.com → R2 → Create bucket
# Backblaze B2: https://www.backblaze.com/b2/cloud-storage.html
# ──────────────────────────────────────────────
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=trading-bot-backups
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_REGION=auto
