{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:server": "tsx watch src/index.ts",
    "dev:workers": "tsx watch src/workers/index.ts",
    "build": "tsup src/index.ts src/workers/index.ts --format esm",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "start": "node dist/index.js",
    "start:workers": "node dist/workers/index.js",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@tb/config": "workspace:*",
    "@tb/data-pipeline": "workspace:*",
    "@tb/db": "workspace:*",
    "@tb/trading-core": "workspace:*",
    "@tb/types": "workspace:*",
    "@bull-board/api": "^6.13.1",
    "@bull-board/fastify": "^6.13.1",
    "@fastify/cors": "^11.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.3.0",
    "@trpc/server": "^11.7.1",
    "bullmq": "^5.71.1",
    "ccxt": "^4.5.45",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.1",
    "ioredis": "^5.10.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.1.2",
    "postgres": "^3.4.5",
    "socket.io": "^4.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tb/eslint-config": "workspace:*",
    "@tb/tsconfig": "workspace:*",
    "@testcontainers/postgresql": "^11.13.0",
    "@types/node": "^20.17.12",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4",
    "testcontainers": "^11.13.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
