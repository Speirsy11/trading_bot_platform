{
  "extends": "@tb/tsconfig/react.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["vitest/globals", "@testing-library/jest-dom"],
    "allowJs": true,
    "incremental": true,
    "jsx": "preserve",
    "declaration": false,
    "declarationMap": false
  },
  "include": ["src", "next-env.d.ts", ".next/types/**/*.ts", "vitest.setup.ts"],
  "exclude": ["node_modules", ".next"]
}
