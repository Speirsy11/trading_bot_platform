{
  "name": "@tb/config",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "tsup src/index.ts --watch",
    "build": "tsup src/index.ts --format esm --dts",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "pino": "^9.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tb/eslint-config": "workspace:*",
    "@tb/tsconfig": "workspace:*",
    "@types/node": "^20.17.12",
    "pino-pretty": "^13.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
