{
  "name": "@tb/data-pipeline",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "tsup src/index.ts --watch",
    "build": "tsup src/index.ts --format esm --dts",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@tb/config": "workspace:^",
    "@tb/db": "workspace:^",
    "@tb/types": "workspace:*",
    "@tb/utils": "workspace:*",
    "better-sqlite3": "^12.8.0",
    "bullmq": "^5.71.1",
    "ccxt": "^4.5.45",
    "csv-stringify": "^6.7.0",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.38.3",
    "ioredis": "^5.10.1",
    "p-limit": "^7.3.0",
    "pino": "^9.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tb/eslint-config": "workspace:*",
    "@tb/tsconfig": "workspace:*",
    "@testcontainers/postgresql": "^11.13.0",
    "@types/better-sqlite3": "^7.6.13",
    "postgres": "^3.4.5",
    "testcontainers": "^11.13.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
