{
  "name": "@tb/types",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "tsup src/index.ts --watch",
    "build": "tsup src/index.ts --format esm --dts",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "@tb/eslint-config": "workspace:*",
    "@tb/tsconfig": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
